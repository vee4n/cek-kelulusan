# ============================================================
# ENVIRONMENT VARIABLES — CEK KELULUSAN APP
# ============================================================
# Copy this file to .env.local for local development
# On Vercel: add these in Project Settings > Environment Variables
# ============================================================

# ── PostgreSQL (Vercel Postgres / Neon / Supabase) ──────────
# For Vercel Postgres: auto-populated when you connect the integration
# For Neon / Supabase: copy from your dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Direct connection (required by Prisma for migrations on connection-pooled dbs)
# If using pgBouncer / Supabase pooler, this should be the direct (non-pooled) URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── Next.js ──────────────────────────────────────────────────
# Only needed if you have a custom domain
# NEXTAUTH_URL="https://yourdomain.com"

# ── Optional: App branding override ──────────────────────────
# NEXT_PUBLIC_SCHOOL_NAME="SMA Negeri 1 Contoh"
# NEXT_PUBLIC_SCHOOL_YEAR="2023/2024"
