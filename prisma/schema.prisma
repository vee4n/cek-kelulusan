// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Siswa {
  id             Int              @id @default(autoincrement())
  nama           String
  ttl            String           // Tempat, Tanggal Lahir — stored as formatted string e.g. "Jakarta, 12 Mei 2006"
  nisn           String           @unique
  nomorInduk     String           @unique  // Used as password
  statusKelulusan StatusKelulusan @default(BELUM_DITENTUKAN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("siswa")
}

enum StatusKelulusan {
  LULUS
  TIDAK_LULUS
  BELUM_DITENTUKAN

  @@map("status_kelulusan")
}
